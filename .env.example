# Environment Configuration Example
# Copy this file to .env and fill in your actual values

# Node Environment
NODE_ENV=development

# Firebase Frontend Configuration (VITE_ prefix required for client-side access)
VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id_here
VITE_FIREBASE_APP_ID=your_app_id_here

# Firebase Backend Configuration (Service Account)
# CRITICAL: For Vercel deployment, use the ENTIRE service account JSON as a single line
# Format: {"type":"service_account","project_id":"...","private_key":"..."}
# You can get this from: Firebase Console -> Project Settings -> Service Accounts -> Generate New Private Key
FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"your-project","private_key":"-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY\n-----END PRIVATE KEY-----\n","client_email":"firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com","client_id":"xxxxxxxxxxxxxxxxxxxxx","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","auth_provider_x509_cert_url":"https://www.googleapis.com/oauth2/v1/certs","client_x509_cert_url":"https://www.googleapis.com/robot/v1/metadata/x509/firebase-adminsdk-xxxxx%40your-project.iam.gserviceaccount.com"}

# Optional: Production URL (for CORS configuration)
PRODUCTION_URL=https://your-domain.com

# Port Configuration (Vercel sets this automatically in production)
PORT=5000

# ==========================================
# VERCEL DEPLOYMENT INSTRUCTIONS
# ==========================================
# 
# 1. Add all VITE_* variables to Vercel:
#    - Go to: Project Settings → Environment Variables
#    - Add each VITE_FIREBASE_* variable above
#    - Make sure they're available for both Production and Preview deployments
#
# 2. Add FIREBASE_SERVICE_ACCOUNT_KEY:
#    - CRITICAL: Copy the ENTIRE JSON object as a single line (no line breaks except in the private_key field)
#    - The private_key field MUST include \n characters for line breaks
#    - Example: {"type":"service_account","project_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\nLINE1\nLINE2\n-----END PRIVATE KEY-----\n",...}
#    
# 3. Verify Environment Variables:
#    - After deployment, visit: https://your-deployment.vercel.app/api/verify
#    - This endpoint will show the status of all connections
#
# 4. Configure Firebase Console:
#    - Go to: Firebase Console → Authentication → Settings → Authorized domains
#    - Add your Vercel deployment domain: your-app.vercel.app
#    - Also add any custom domains you're using
#
# 5. Deploy:
#    - Push to your Git repository
#    - Vercel will automatically build and deploy
#    - Monitor the build logs for any errors
#
# ==========================================
# TROUBLESHOOTING
# ==========================================
#
# Problem: "Products not loading in production"
# Solution: 
#   1. Verify all VITE_* variables are set in Vercel
#   2. Check that FIREBASE_SERVICE_ACCOUNT_KEY is properly formatted (single line JSON)
#   3. Visit /api/verify to check Firebase Admin connection
#   4. Check Vercel function logs for errors
#
# Problem: "Firebase Admin SDK not initialized"
# Solution:
#   1. Verify FIREBASE_SERVICE_ACCOUNT_KEY is set correctly
#   2. Make sure the JSON is valid (test with JSON.parse() locally)
#   3. Ensure the service account has Firestore read/write permissions
#   4. Check that the private_key field includes \n for line breaks
#
# Problem: "CORS errors in production"
# Solution:
#   1. Add your Vercel domain to Firebase Console authorized domains
#   2. Verify the domain in Vercel project settings matches
#   3. Check browser console for specific CORS error messages
#
# Problem: "Authentication not working"
# Solution:
#   1. Verify your domain is in Firebase authorized domains
#   2. Check that VITE_FIREBASE_AUTH_DOMAIN is correct
#   3. Ensure all VITE_* variables are set before build
#
